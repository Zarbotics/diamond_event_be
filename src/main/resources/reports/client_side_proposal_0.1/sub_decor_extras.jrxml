<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="sub_decor_extras" pageWidth="595" pageHeight="842" columnWidth="523" leftMargin="36" rightMargin="36" topMargin="0" bottomMargin="0" uuid="c6000000-0000-0000-0000-000000000001">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="live_db_04_26.xml"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.unit.height" value="px"/>
	<property name="com.jaspersoft.studio.unit.width" value="px"/>
	<parameter name="P_EVENT_MASTER_ID" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[97]]></defaultValueExpression>
	</parameter>
	<queryString language="SQL">
		<![CDATA[SELECT
			'D'                                              AS source_type,
			edcs.ser_event_decor_category_selection_id      AS category_id,
			COALESCE(dcm.txt_decor_category_name, '')        AS category_name,
			edcs.num_price                                   AS category_price,
			COALESCE(dcm.num_display_order, 999)             AS category_order,
			edps.ser_event_decor_property_id                 AS property_id,
			COALESCE(pm.txt_property_name, '')               AS property_name,
			COALESCE(pm.num_display_order, 999)              AS property_order,
			COALESCE(dcpv.bln_is_document, FALSE)            AS value_is_image,
			dcpv.txt_property_value                          AS value_text,
			NULL                                             AS value_image_path,
			COALESCE(dcpv.ser_property_value_id, 0)          AS value_order,
			em1.txt_decore_remarks,
			NULL												AS txt_event_extras_remarks
		FROM event_decor_category_selection edcs
		JOIN decor_category_master dcm
			ON edcs.ser_decor_category_id = dcm.ser_decor_category_id
		LEFT JOIN event_decor_property_selection edps
			ON edps.ser_event_decor_category_selection_id = edcs.ser_event_decor_category_selection_id
		LEFT JOIN decor_category_property_master pm
			ON edps.ser_property_id = pm.ser_property_id
		LEFT JOIN event_decor_property_value_selection edpvs
			ON edpvs.ser_event_decor_property_id = edps.ser_event_decor_property_id
		LEFT JOIN decor_category_property_value dcpv
			ON edpvs.ser_property_value_id = dcpv.ser_property_value_id
		LEFT JOIN decor_category_property_value_document dcpvd
			ON dcpv.ser_document_id = dcpvd.ser_document_id
		LEFT JOIN event_master em1
			ON edcs.ser_event_master_id = em1.ser_event_master_id
		WHERE edcs.ser_event_master_id = $P{P_EVENT_MASTER_ID}

		UNION ALL

		SELECT
			'E'                                              AS source_type,
			eds.ser_extras_selection_id                      AS category_id,
			COALESCE(dem.txt_extras_name, '')                AS category_name,
			eds.num_price                                    AS category_price,
			COALESCE(dem.num_display_order, 999)             AS category_order,
			NULL                                             AS property_id,
			NULL                                             AS property_name,
			0                                                AS property_order,
			COALESCE(deo.bln_is_document, FALSE)             AS value_is_image,
			deo.txt_option_name                              AS value_text,
			NULL                                             AS value_image_path,
			COALESCE(deo.ser_extra_option_id, 0)             AS value_order,
			NULL                                       AS txt_decore_remarks,
			em2.txt_event_extras_remarks
		FROM event_decor_extras_selection eds
		LEFT JOIN decor_extras_master dem
			ON eds.ser_extras_id = dem.ser_extras_id
		LEFT JOIN decor_extras_option deo
			ON eds.ser_extra_option_id = deo.ser_extra_option_id
		LEFT JOIN decor_extras_option_document deod
			ON deo.ser_document_id = deod.ser_document_id
		LEFT JOIN event_master em2
			ON eds.ser_event_master_id = em2.ser_event_master_id
		WHERE eds.ser_event_master_id = $P{P_EVENT_MASTER_ID}
		  AND eds.bln_is_services = FALSE

		ORDER BY source_type, category_order, category_name,
		         property_order, property_name, value_order]]>
	</queryString>
