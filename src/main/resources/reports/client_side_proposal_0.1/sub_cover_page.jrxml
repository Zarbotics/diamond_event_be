	<queryString language="SQL">
		<![CDATA[SELECT
            COALESCE(e.txt_event_master_name, 'Your Wedding Celebration') AS event_name,
            e.dte_event_date,
            COALESCE(et.txt_event_type_name, '') AS event_type_name
        FROM event_master e
        LEFT JOIN event_type et ON e.ser_event_type_id = et.ser_event_type_id
        WHERE e.ser_event_master_id = $P{P_EVENT_MASTER_ID}
          AND e.bln_is_deleted = FALSE]]>
	</queryString>
	<field name="event_name" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.label" value="event_name"/>
	</field>
	<field name="dte_event_date" class="java.sql.Timestamp">
