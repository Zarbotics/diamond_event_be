	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="DataAdapter.xml"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.unit.height" value="px"/>
	<property name="com.jaspersoft.studio.unit.width" value="px"/>

	<parameter name="P_EVENT_MASTER_ID" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[97]]></defaultValueExpression>
	</parameter>

	<queryString language="SQL">
		<![CDATA[
		SELECT
			eb.num_food_amount      AS food_amount,
			eb.num_services_amount  AS services_amount,
			eb.num_decor_amount     AS decor_amount,
			eb.num_qouted_price     AS quoted_price,
			eb.num_paid_amount      AS paid_amount,
			eb.num_discount         AS discount
		FROM event_budget eb
		WHERE eb.ser_event_master_id = $P{P_EVENT_MASTER_ID}
		]]>
	</queryString>

	<field name="food_amount"     class="java.math.BigDecimal"/>
	<field name="services_amount" class="java.math.BigDecimal"/>
	<field name="decor_amount"    class="java.math.BigDecimal"/>
	<field name="quoted_price"    class="java.math.BigDecimal"/>
	<field name="paid_amount"     class="java.math.BigDecimal"/>
	<field name="discount"        class="java.math.BigDecimal"/>

