<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="sub_event_details" pageWidth="595" pageHeight="842" columnWidth="523" leftMargin="36" rightMargin="36" topMargin="0" bottomMargin="0" uuid="c3000000-0000-0000-0000-000000000001">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="DataAdapter.xml"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.unit.height" value="px"/>
	<property name="com.jaspersoft.studio.unit.width" value="px"/>
	<parameter name="P_EVENT_MASTER_ID" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[97]]></defaultValueExpression>
	</parameter>
	<queryString language="SQL">
		<![CDATA[SELECT
            -- Client / contact
            NULLIF(TRIM(
                COALESCE(c.txt_first_name, '') ||
                CASE WHEN c.txt_last_name IS NOT NULL AND c.txt_last_name <> ''
                     THEN ' ' || c.txt_last_name ELSE '' END
            ), '')                                              AS client_name,
            COALESCE(c.txt_phone_number_1, '')                 AS contact_no,
            COALESCE(c.txt_email, '')                          AS email,

            -- Contact person (separate from client)
            NULLIF(TRIM(
                COALESCE(e.txt_contact_person_first_name, '') ||
                CASE WHEN e.txt_contact_person_last_name IS NOT NULL
                          AND e.txt_contact_person_last_name <> ''
                     THEN ' ' || e.txt_contact_person_last_name ELSE '' END
            ), '')                                              AS contact_person_name,
            COALESCE(e.txt_contact_person_phone_no, '')        AS contact_person_phone,

            -- Bride / Groom — safe concat covering all null/empty edge cases
            NULLIF(TRIM(
                COALESCE(e.txt_groom_first_name, '') ||
                CASE WHEN e.txt_groom_last_name IS NOT NULL AND e.txt_groom_last_name <> ''
                     THEN ' ' || e.txt_groom_last_name ELSE '' END
            ), '')                                              AS groom_name,
            NULLIF(TRIM(
                COALESCE(e.txt_bride_first_name, '') ||
                CASE WHEN e.txt_bride_last_name IS NOT NULL AND e.txt_bride_last_name <> ''
                     THEN ' ' || e.txt_bride_last_name ELSE '' END
            ), '')                                              AS bride_name,

            -- Event details
            e.dte_event_date,
            COALESCE(CAST(e.num_number_of_guests AS VARCHAR), '') AS num_guests,
            COALESCE(CAST(e.num_number_of_tables AS VARCHAR), '') AS num_tables,

            -- Venue: name + hall name
            NULLIF(TRIM(
                COALESCE(v.txt_venue_name, '') ||
                CASE WHEN vd.txt_hall_name IS NOT NULL AND vd.txt_hall_name <> ''
                     THEN ' - ' || vd.txt_hall_name ELSE '' END
            ), '')                                              AS venue_display,

            -- Running order (all 14 VARCHAR time fields)
            r.txt_guest_arrival,
            r.txt_groom_guest_arrival,
            r.txt_bride_guest_arrival,
            r.txt_barat_arrival,
            r.txt_nikah,
            r.txt_bride_entrance,
            r.txt_groom_entrance,
            r.txt_couples_entrance,
            r.txt_dua,
            r.txt_cake_cutting,
            r.txt_ring_exchange,
            r.txt_rams,
            r.txt_speeches,
            r.txt_dance,
            r.txt_meal,
            r.dte_end_of_night,

            -- Running order summary code
            COALESCE(r.txt_event_running_order_code, '') AS running_order_code

        FROM event_master e
        LEFT JOIN customer_master      c   ON e.ser_cust_id                  = c.ser_cust_id
        LEFT JOIN venue_master_detail  vd  ON e.ser_venue_master_detail_id   = vd.ser_venue_master_detail_id
        LEFT JOIN venue_master         v   ON vd.ser_venue_master_id         = v.ser_venue_master_id
        LEFT JOIN event_running_order  r   ON e.ser_event_running_order_id   = r.ser_event_running_order_id
        WHERE e.ser_event_master_id = $P{P_EVENT_MASTER_ID}
          AND e.bln_is_deleted = FALSE]]>
	</queryString>
