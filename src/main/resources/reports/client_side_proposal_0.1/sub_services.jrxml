<?xml version="1.0" encoding="UTF-8"?>
<!-- Diamond Events - Services Sub-Report (Section 04) -->
<!-- JasperReports 6.11.0 | Jaspersoft Studio 6.11.0 -->
<jasperReport
	xmlns="http://jasperreports.sourceforge.net/jasperreports"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
	name="sub_services"
	pageWidth="595" pageHeight="842"
	columnWidth="523" leftMargin="36" rightMargin="36"
	topMargin="0" bottomMargin="0"
	uuid="c5000000-0000-0000-0000-000000000001">

	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="DataAdapter.xml"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.unit.height" value="px"/>
	<property name="com.jaspersoft.studio.unit.width" value="px"/>

	<parameter name="P_EVENT_MASTER_ID" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[97]]></defaultValueExpression>
	</parameter>

	<queryString language="SQL">
		<![CDATA[
		SELECT
			eds.ser_extras_selection_id,
			dem.ser_extras_id                          AS service_id,
			COALESCE(dem.txt_extras_name, '')          AS service_name,
			COALESCE(dem.num_display_order, 999)       AS service_order,
			eds.num_price                              AS service_price,
			deo.ser_extra_option_id                    AS option_id,
			COALESCE(deo.txt_option_name, '')          AS option_name
		FROM event_decor_extras_selection eds
		LEFT JOIN decor_extras_master dem
			ON eds.ser_extras_id = dem.ser_extras_id
		LEFT JOIN decor_extras_option deo
			ON eds.ser_extra_option_id = deo.ser_extra_option_id
		WHERE eds.ser_event_master_id = $P{P_EVENT_MASTER_ID}
		  AND eds.bln_is_services = TRUE
		ORDER BY service_order, service_name, option_name
		]]>
	</queryString>

	<field name="ser_extras_selection_id" class="java.lang.Integer"/>
	<field name="service_id"    class="java.lang.Integer"/>
	<field name="service_name"  class="java.lang.String"/>
	<field name="service_order" class="java.lang.Integer"/>
	<field name="service_price" class="java.math.BigDecimal"/>
	<field name="option_id"     class="java.lang.Integer"/>
	<field name="option_name"   class="java.lang.String"/>

	<!-- Group by service (each service = one dark header box) -->
	<group name="serviceGroup">
		<groupExpression><![CDATA[$F{service_id}]]></groupExpression>
		<groupHeader>
			<band height="34" splitType="Prevent">
				<!-- Dark box background -->
				<rectangle>
					<reportElement mode="Opaque" x="0" y="4" width="523" height="26"
						forecolor="#C5A367" backcolor="#1A1A10"
						uuid="c5000000-0000-0000-0000-000000000010"/>
					<graphicElement><pen lineWidth="0.75" lineColor="#C5A367"/></graphicElement>
				</rectangle>
				<!-- Gold left accent bar -->
				<rectangle>
					<reportElement mode="Opaque" x="0" y="4" width="3" height="26"
						forecolor="#C5A367" backcolor="#C5A367"
						uuid="c5000000-0000-0000-0000-000000000011"/>
					<graphicElement><pen lineWidth="0.0"/></graphicElement>
				</rectangle>
				<!-- Service name -->
				<textField isBlankWhenNull="true">
					<reportElement x="12" y="4" width="370" height="26"
						forecolor="#C5A367"
						uuid="c5000000-0000-0000-0000-000000000012"/>
					<textElement verticalAlignment="Middle">
						<font fontName="Inter" size="7.5" isBold="true"  />
					</textElement>
					<textFieldExpression><![CDATA[($F{service_name} != null) ? $F{service_name}.toUpperCase() : ""]]></textFieldExpression>
				</textField>
				<!-- Price — only when not null and > 0 -->
				<textField isBlankWhenNull="true">
					<reportElement x="390" y="4" width="130" height="26"
						forecolor="#C5A367"
						uuid="c5000000-0000-0000-0000-000000000013">
						<printWhenExpression><![CDATA[$F{service_price} != null && $F{service_price}.compareTo(java.math.BigDecimal.ZERO) > 0]]></printWhenExpression>
					</reportElement>
					<textElement textAlignment="Right" verticalAlignment="Middle">
						<font fontName="Inter" size="7.5" isBold="true"  />
					</textElement>
					<textFieldExpression><![CDATA["£" + new java.text.DecimalFormat("#,##0.00").format($F{service_price})]]></textFieldExpression>
				</textField>
			</band>
		</groupHeader>
		<groupFooter>
			<band height="14"/>
		</groupFooter>
	</group>

	<!-- CORRECT JR 6.11 band order:
	     background → title → pageHeader → detail → pageFooter → summary → noData -->

	<background>
		<band height="842" splitType="Stretch">
			<rectangle>
				<reportElement mode="Opaque" x="-36" y="0" width="595" height="842"
					forecolor="#0C0C0C" backcolor="#0C0C0C"
					uuid="c5000000-0000-0000-0000-000000000002"/>
				<graphicElement><pen lineWidth="0.0"/></graphicElement>
			</rectangle>
		</band>
	</background>

	<!-- Title: break forces new page start when called from master detail band -->
	<title>
		<band height="1" splitType="Prevent">
			<break>
				<reportElement x="0" y="0" width="1" height="1"
					uuid="c5000000-0000-0000-0000-000000000099"/>
			</break>
		</band>
	</title>

	<!-- Page header: repeats on every page of this section -->
	<pageHeader>
		<band height="155" splitType="Prevent">
			<!-- Dark background -->
			<rectangle>
				<reportElement mode="Opaque" x="-36" y="0" width="595" height="115"
					forecolor="#0C0C0C" backcolor="#0C0C0C"
					uuid="c5000000-0000-0000-0000-000000000003"/>
				<graphicElement><pen lineWidth="0.0"/></graphicElement>
			</rectangle>
			<!-- 6px gold top bar -->
			<rectangle>
				<reportElement mode="Opaque" x="-36" y="0" width="595" height="6"
					forecolor="#C5A367" backcolor="#C5A367"
					uuid="c5000000-0000-0000-0000-000000000004"/>
				<graphicElement><pen lineWidth="0.0"/></graphicElement>
			</rectangle>
			<!-- "04" ghost number -->
			<staticText>
				<reportElement x="0" y="5" width="124" height="90"
					forecolor="#1E1608"
					uuid="c5000000-0000-0000-0000-000000000005"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Playfair Display" size="76" isBold="true"/>
				</textElement>
				<text><![CDATA[04]]></text>
			</staticText>
			<!-- Gold accent bar — x=13 aligned with title (leftMargin=36) -->
			<rectangle>
				<reportElement mode="Opaque" x="13" y="45" width="4" height="45"
					forecolor="#C5A367" backcolor="#C5A367"
					uuid="c5000000-0000-0000-0000-000000000006"/>
				<graphicElement><pen lineWidth="0.0"/></graphicElement>
			</rectangle>
			<!-- SERVICES title -->
			<staticText>
				<reportElement x="26" y="51" width="400" height="30"
					forecolor="#C5A367"
					uuid="c5000000-0000-0000-0000-000000000007"/>
				<textElement textAlignment="Left" verticalAlignment="Middle">
					<font fontName="Inter" size="22" isBold="false"  />
				</textElement>
				<text><![CDATA[SERVICES]]></text>
			</staticText>
			<!-- Gold hairline rule -->
			<line>
				<reportElement x="0" y="102" width="523" height="1"
					forecolor="#C5A367"
					uuid="c5000000-0000-0000-0000-000000000008"/>
				<graphicElement><pen lineWidth="0.75" lineColor="#C5A367"/></graphicElement>
			</line>
			<!-- Intro paragraph — only on first page of this section -->
			<staticText>
				<reportElement x="0" y="112" width="523" height="36"
					forecolor="#BFBFBF"
					uuid="c5000000-0000-0000-0000-000000000097">
					<printWhenExpression><![CDATA[$V{PAGE_NUMBER} == 1]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Left" verticalAlignment="Middle">
					<font fontName="Inter" size="8.5"  />
				</textElement>
				<text><![CDATA[The professional services selected to ensure your event runs seamlessly from start to finish.]]></text>
			</staticText>
		</band>
	</pageHeader>

	<!-- Detail: one row per option under each service -->
	<detail>
		<band height="26" splitType="Prevent">
			<rectangle>
				<reportElement mode="Opaque" x="-36" y="0" width="595" height="26"
					forecolor="#0C0C0C" backcolor="#0C0C0C"
					uuid="c5000000-0000-0000-0000-000000000025"/>
				<graphicElement><pen lineWidth="0.0"/></graphicElement>
			</rectangle>
			<!-- Bullet -->
			<staticText>
				<reportElement x="8" y="6" width="12" height="14"
					forecolor="#C5A367"
					uuid="c5000000-0000-0000-0000-000000000026">
					<printWhenExpression><![CDATA[$F{option_name} != null && !$F{option_name}.trim().isEmpty()]]></printWhenExpression>
				</reportElement>
				<textElement verticalAlignment="Middle">
					<font fontName="Inter" size="9"  />
				</textElement>
				<text><![CDATA[•]]></text>
			</staticText>
			<!-- Option name -->
			<textField isBlankWhenNull="true">
				<reportElement x="22" y="6" width="501" height="14"
					forecolor="#CCCCCC"
					uuid="c5000000-0000-0000-0000-000000000027">
					<printWhenExpression><![CDATA[$F{option_name} != null && !$F{option_name}.trim().isEmpty()]]></printWhenExpression>
				</reportElement>
				<textElement verticalAlignment="Middle">
					<font fontName="Inter" size="9"  />
				</textElement>
				<textFieldExpression><![CDATA[$F{option_name}]]></textFieldExpression>
			</textField>
		</band>
	</detail>

	<pageFooter>
		<band height="47" splitType="Prevent">
			<line>
				<reportElement x="-36" y="0" width="595" height="1"
					forecolor="#C5A367"
					uuid="c5000000-0000-0000-0000-000000000009"/>
				<graphicElement><pen lineWidth="0.5" lineColor="#C5A367"/></graphicElement>
			</line>
			<staticText>
				<reportElement x="0" y="13" width="150" height="14"
					forecolor="#C5A367"
					uuid="c5000000-0000-0000-0000-000000000020"/>
				<textElement textAlignment="Left" verticalAlignment="Middle">
					<font fontName="Playfair Display" size="7" isBold="true"/>
				</textElement>
				<text><![CDATA[DIAMOND EVENTS]]></text>
			</staticText>
			<staticText>
				<reportElement x="373" y="13" width="150" height="14"
					forecolor="#E0C590"
					uuid="c5000000-0000-0000-0000-000000000021"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font fontName="Inter" size="7"  />
				</textElement>
				<text><![CDATA[WWW.DIAMONDEVENTS.UK]]></text>
			</staticText>
			<rectangle>
				<reportElement mode="Opaque" x="-36" y="41" width="595" height="6"
					forecolor="#C5A367" backcolor="#C5A367"
					uuid="c5000000-0000-0000-0000-000000000022"/>
				<graphicElement><pen lineWidth="0.0"/></graphicElement>
			</rectangle>
		</band>
	</pageFooter>

	<summary>
		<band height="20" splitType="Prevent">
			<rectangle>
				<reportElement mode="Opaque" x="-36" y="0" width="595" height="20"
					forecolor="#0C0C0C" backcolor="#0C0C0C"
					uuid="c5000000-0000-0000-0000-000000000028"/>
				<graphicElement><pen lineWidth="0.0"/></graphicElement>
			</rectangle>
		</band>
	</summary>

	<noData>
		<band height="40">
			<rectangle>
				<reportElement mode="Opaque" x="-36" y="0" width="595" height="40"
					forecolor="#0C0C0C" backcolor="#0C0C0C"
					uuid="c5000000-0000-0000-0000-000000000031"/>
				<graphicElement><pen lineWidth="0.0"/></graphicElement>
			</rectangle>
			<staticText>
				<reportElement x="0" y="10" width="523" height="20"
					forecolor="#555555"
					uuid="c5000000-0000-0000-0000-000000000032"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Inter" size="9"  />
				</textElement>
				<text><![CDATA[No services have been selected for this event.]]></text>
			</staticText>
		</band>
	</noData>

</jasperReport>
