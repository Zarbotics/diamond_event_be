	<parameter name="P_EVENT_MASTER_ID" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[97]]></defaultValueExpression>
	</parameter>
	<queryString language="SQL">
		<![CDATA[SELECT
            COALESCE(emss.ser_event_menu_category_id, 0)  AS category_id,
            COALESCE(cat.txt_name, 'UNCATEGORISED')        AS category_name,
            COALESCE(cat.num_display_order, 999)           AS category_order,
            emcs.num_final_price                           AS category_price,
            emss.ser_event_menu_sub_category_id            AS subcategory_id,
            COALESCE(sub.txt_name, '')                     AS subcategory_name,
            COALESCE(sub.num_display_order, 999)           AS subcategory_order,
            emss.num_final_price                           AS subcategory_price,
            COALESCE(mi.txt_name, '')                      AS item_name,
            COALESCE(mi.num_display_order, 999)            AS item_order
        FROM event_menu_food_selection emfs
        LEFT JOIN event_menu_subcategory_selection emss
               ON emfs.ser_event_menu_sub_category_id = emss.ser_event_menu_sub_category_id
        LEFT JOIN event_menu_category_selection emcs
               ON emss.ser_event_menu_category_id = emcs.ser_event_menu_category_id
        LEFT JOIN menu_item cat
               ON emcs.ser_menu_category_id = cat.ser_menu_item_id
        LEFT JOIN menu_item sub
               ON emss.ser_menu_sub_category_id = sub.ser_menu_item_id
        LEFT JOIN menu_item mi
               ON emfs.ser_menu_item_id = mi.ser_menu_item_id
        WHERE emfs.ser_event_master_id = $P{P_EVENT_MASTER_ID}
        ORDER BY category_order, category_name,
                 subcategory_order, subcategory_name,
                 item_order, item_name]]>
	</queryString>
