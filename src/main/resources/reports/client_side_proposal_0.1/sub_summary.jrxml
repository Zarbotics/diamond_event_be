					<font fontName="Playfair Display" size="24" isBold="true"/>
				</textElement>
				<text><![CDATA[Welcome to Diamond Events]]></text>
			</staticText>
			<staticText>
				<reportElement x="36" y="152" width="400" height="18" forecolor="#C5A367" uuid="c2000000-0000-0000-0000-000000000009"/>
				<textElement textAlignment="Left" verticalAlignment="Middle">
					<font fontName="Playfair Display" size="12" isBold="false" isItalic="true"/>
				</textElement>
				<text><![CDATA[Where Your Vision Becomes a Timeless Reality]]></text>
			</staticText>
			<line>
				<reportElement x="36" y="177" width="60" height="1" forecolor="#C5A367" uuid="c2000000-0000-0000-0000-000000000010"/>
				<graphicElement>
					<pen lineWidth="2.0" lineColor="#C5A367"/>
				</graphicElement>
			</line>
			<staticText>
				<reportElement x="36" y="188" width="523" height="52" forecolor="#BFBFBF" uuid="c2000000-0000-0000-0000-000000000011"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Inter" size="8.5" isBold="false"/>
				</textElement>
				<text><![CDATA[On behalf of the entire Diamond Events family, we are truly honoured and delighted that you are considering us to bring your most cherished celebration to life. With over two decades of unrivalled expertise in crafting extraordinary events, Diamond Events has built a legacy rooted in excellence, integrity, and an unwavering passion for perfection.]]></text>
			</staticText>
			<staticText>
				<reportElement x="36" y="248" width="523" height="52" forecolor="#BFBFBF" uuid="c2000000-0000-0000-0000-000000000012"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Inter" size="8.5" isBold="false"/>
				</textElement>
				<text><![CDATA[From breathtaking bespoke decor and statement floral installations to exquisite cuisine and seamless, sophisticated entertainment, every element we create is thoughtfully curated with the finest attention to detail - because for us, nothing less than perfection is ever an option.]]></text>
			</staticText>
			<staticText>
				<reportElement x="36" y="308" width="523" height="40" forecolor="#BFBFBF" uuid="c2000000-0000-0000-0000-000000000013"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Inter" size="8.5" isBold="false"/>
				</textElement>
				<text><![CDATA[As you explore this proposal, we invite you to envision a celebration that is not only a reflection of your unique story, but a truly unforgettable experience that you, your family, and your guests will treasure for a lifetime.]]></text>
			</staticText>
			<rectangle>
				<reportElement mode="Opaque" x="36" y="510" width="147" height="120" forecolor="#C5A367" backcolor="#212121" uuid="c2000000-0000-0000-0000-000000000014"/>
