					<font fontName="Playfair Display" size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Bespoke Service]]></text>
			</staticText>
			<staticText>
				<reportElement x="48" y="560" width="123" height="60" forecolor="#A0A0A0" uuid="c2000000-0000-0000-0000-000000000018"/>
